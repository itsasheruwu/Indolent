<Window
    x:Class="Indolent.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="{StaticResource AppPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="32,24,32,16" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="8">
                <TextBlock
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="Indolent" />
                <TextBlock
                    Foreground="{StaticResource AppMutedBrush}"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="Resident Codex widget for short OCR-based answers." />
            </StackPanel>

            <Button
                Grid.Column="1"
                Click="OnOpenWidgetClicked"
                Content="Show Widget"
                Style="{StaticResource AccentButtonStyle}" />
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel MaxWidth="920" Padding="32,8,32,32" Spacing="20">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Padding="20"
                        Background="{StaticResource AppCardBrush}"
                        BorderBrush="{StaticResource AppCardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel Spacing="16">
                            <TextBlock
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="Codex status" />
                            <Grid ColumnSpacing="12" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="CLI" />
                                <TextBlock
                                    Grid.Column="1"
                                    Foreground="{StaticResource AppMutedBrush}"
                                    Text="{x:Bind ViewModel.CodexVersionText, Mode=OneWay}" />

                                <TextBlock Grid.Row="1" Text="Session" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Foreground="{StaticResource AppMutedBrush}"
                                    Text="{x:Bind ViewModel.LoginStatusText, Mode=OneWay}" />

                                <TextBlock Grid.Row="2" Text="Last result" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Foreground="{StaticResource AppMutedBrush}"
                                    Text="{x:Bind ViewModel.LastAnswerSummary, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button
                                    Click="OnRefreshClicked"
                                    Content="Re-check"
                                    IsEnabled="{x:Bind ViewModel.CanRefresh, Mode=OneWay}" />
                                <ProgressRing
                                    Width="18"
                                    Height="18"
                                    IsActive="{x:Bind ViewModel.IsRefreshing, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="20"
                        Background="{StaticResource AppCardBrush}"
                        BorderBrush="{StaticResource AppCardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel Spacing="16">
                            <TextBlock
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="Model and widget" />
                            <StackPanel Spacing="10">
                                <TextBlock Text="Available models" />
                                <ComboBox
                                    x:Name="ModelComboBox"
                                    IsEnabled="{x:Bind ViewModel.IsReady, Mode=OneWay}"
                                    DisplayMemberPath="DisplayName"
                                    ItemsSource="{x:Bind ViewModel.AvailableModels, Mode=OneWay}"
                                    PlaceholderText="Choose a Codex model"
                                    SelectionChanged="OnModelComboBoxSelectionChanged"
                                    SelectedValue="{x:Bind ViewModel.SelectedModel, Mode=TwoWay}"
                                    SelectedValuePath="Slug" />
                                <TextBlock
                                    Foreground="{StaticResource AppMutedBrush}"
                                    Text="{x:Bind ViewModel.AvailableModelsSummary, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.SelectedModelDescription, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Foreground="{StaticResource AppMutedBrush}"
                                    Text="{x:Bind ViewModel.SelectedModelSupportText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel
                                Spacing="10"
                                Visibility="{x:Bind ViewModel.ShowReasoningSelectorVisibility, Mode=OneWay}">
                                <TextBlock Text="Reasoning mode" />
                                <ComboBox
                                    x:Name="ReasoningComboBox"
                                    DisplayMemberPath="DisplayName"
                                    IsEnabled="{x:Bind ViewModel.IsReady, Mode=OneWay}"
                                    ItemsSource="{x:Bind ViewModel.ReasoningOptions, Mode=OneWay}"
                                    SelectionChanged="OnReasoningComboBoxSelectionChanged"
                                    SelectedValue="{x:Bind ViewModel.SelectedReasoningEffort, Mode=TwoWay}"
                                    SelectedValuePath="Effort" />
                                <TextBlock
                                    Foreground="{StaticResource AppMutedBrush}"
                                    Text="{x:Bind ViewModel.SelectedReasoningDescription, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <ToggleSwitch
                                Header="Show widget on startup"
                                IsOn="{x:Bind ViewModel.StartWithWidget, Mode=TwoWay}" />

                            <TextBlock
                                Foreground="{StaticResource AppMutedBrush}"
                                Text="The app reads account-visible models from the local Codex cache, then passes the selected model to `codex -m` and the reasoning mode through `model_reasoning_effort` when that model supports it."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Padding="20"
                    Background="{StaticResource AppSubtleCardBrush}"
                    BorderBrush="{StaticResource AppCardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{x:Bind ViewModel.ShowInstallBlockerVisibility, Mode=OneWay}">
                    <StackPanel Spacing="16">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="{x:Bind ViewModel.BlockingTitle, Mode=OneWay}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.BlockingMessage, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                Click="OnOpenInstallGuideClicked"
                                Content="Open install guide"
                                Style="{StaticResource AccentButtonStyle}" />
                            <Button
                                Click="OnRefreshClicked"
                                Content="Re-check" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Padding="20"
                    Background="{StaticResource AppSubtleCardBrush}"
                    BorderBrush="{StaticResource AppCardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="12">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="CLI wrapper behavior" />
                        <TextBlock
                            Foreground="{StaticResource AppMutedBrush}"
                            Text="Indolent does not manage authentication. It reuses whatever Codex CLI session is already available and only shells out to Codex when needed."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
