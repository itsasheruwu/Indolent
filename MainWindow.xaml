<Window
    x:Class="Indolent.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="{StaticResource AppPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="32,24,32,16" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="8">
                <TextBlock
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="Indolent" />
                <TextBlock
                    Foreground="{StaticResource AppMutedBrush}"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="{x:Bind ViewModel.AppDescriptionText, Mode=OneWay}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                <Button
                    Click="OnOpenLogsClicked"
                    Content="Open Logs" />
                <Button
                    Click="OnToggleTerminalViewClicked"
                    Content="{x:Bind ViewModel.TerminalToggleText, Mode=OneWay}" />
                <Button
                    Click="OnOpenWidgetClicked"
                    Content="Show Widget"
                    Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" Visibility="{x:Bind ViewModel.ShowSettingsViewVisibility, Mode=OneWay}">
            <StackPanel MaxWidth="920" Padding="32,8,32,32" Spacing="20">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Padding="20"
                        Background="{StaticResource AppCardBrush}"
                        BorderBrush="{StaticResource AppCardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel Spacing="16">
                            <TextBlock
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="{x:Bind ViewModel.StatusCardTitle, Mode=OneWay}" />
                            <Grid ColumnSpacing="12" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="{x:Bind ViewModel.CliLabelText, Mode=OneWay}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Foreground="{StaticResource AppMutedBrush}"
                                    Text="{x:Bind ViewModel.VersionText, Mode=OneWay}" />

                                <TextBlock Grid.Row="1" Text="Session" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Foreground="{StaticResource AppMutedBrush}"
                                    Text="{x:Bind ViewModel.LoginStatusText, Mode=OneWay}" />

                                <TextBlock Grid.Row="2" Text="Last result" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Foreground="{StaticResource AppMutedBrush}"
                                    Text="{x:Bind ViewModel.LastAnswerSummary, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button
                                    Click="OnRefreshClicked"
                                    Content="Re-check"
                                    IsEnabled="{x:Bind ViewModel.CanRefresh, Mode=OneWay}" />
                                <ProgressRing
                                    Width="18"
                                    Height="18"
                                    IsActive="{x:Bind ViewModel.IsRefreshing, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="20"
                        Background="{StaticResource AppCardBrush}"
                        BorderBrush="{StaticResource AppCardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel Spacing="16">
                            <TextBlock
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="{x:Bind ViewModel.ProviderSectionTitle, Mode=OneWay}" />
                            <StackPanel Spacing="10">
                                <TextBlock Text="Provider" />
                                <ComboBox
                                    x:Name="ProviderComboBox"
                                    DisplayMemberPath="DisplayName"
                                    ItemsSource="{x:Bind ViewModel.AvailableProviders, Mode=OneWay}"
                                    SelectionChanged="OnProviderComboBoxSelectionChanged"
                                    SelectedValue="{x:Bind ViewModel.SelectedProviderId, Mode=TwoWay}"
                                    SelectedValuePath="Id" />
                                <TextBlock Text="Available models" />
                                <ComboBox
                                    x:Name="ModelComboBox"
                                    IsEnabled="{x:Bind ViewModel.IsReady, Mode=OneWay}"
                                    DisplayMemberPath="DisplayName"
                                    ItemsSource="{x:Bind ViewModel.AvailableModels, Mode=OneWay}"
                                    PlaceholderText="Choose a model"
                                    SelectionChanged="OnModelComboBoxSelectionChanged"
                                    SelectedValue="{x:Bind ViewModel.SelectedModel, Mode=TwoWay}"
                                    SelectedValuePath="Slug" />
                                <TextBlock
                                    Foreground="{StaticResource AppMutedBrush}"
                                    Text="{x:Bind ViewModel.AvailableModelsSummary, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.SelectedModelDescription, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Foreground="{StaticResource AppMutedBrush}"
                                    Text="{x:Bind ViewModel.SelectedModelSupportText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel
                                Spacing="10"
                                Visibility="{x:Bind ViewModel.ShowReasoningSelectorVisibility, Mode=OneWay}">
                                <TextBlock Text="Reasoning mode" />
                                <ComboBox
                                    x:Name="ReasoningComboBox"
                                    DisplayMemberPath="DisplayName"
                                    IsEnabled="{x:Bind ViewModel.IsReady, Mode=OneWay}"
                                    ItemsSource="{x:Bind ViewModel.ReasoningOptions, Mode=OneWay}"
                                    SelectionChanged="OnReasoningComboBoxSelectionChanged"
                                    SelectedValue="{x:Bind ViewModel.SelectedReasoningEffort, Mode=TwoWay}"
                                    SelectedValuePath="Effort" />
                                <TextBlock
                                    Foreground="{StaticResource AppMutedBrush}"
                                    Text="{x:Bind ViewModel.SelectedReasoningDescription, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <ToggleSwitch
                                Header="Show widget on startup"
                                IsOn="{x:Bind ViewModel.StartWithWidget, Mode=TwoWay}" />

                            <ToggleSwitch
                                Header="Save current model on restart"
                                IsOn="{x:Bind ViewModel.SaveCurrentModelOnRestart, Mode=TwoWay}" />

                            <ToggleSwitch
                                Header="Agent mode"
                                IsOn="{x:Bind ViewModel.AgentModeEnabled, Mode=TwoWay}" />

                            <ToggleSwitch
                                Header="Loop"
                                IsOn="{x:Bind ViewModel.AgentLoopEnabled, Mode=TwoWay}"
                                Visibility="{x:Bind ViewModel.ShowAgentLoopVisibility, Mode=OneWay}" />

                            <TextBlock
                                Foreground="{StaticResource AppMutedBrush}"
                                Text="{x:Bind ViewModel.AgentModeDescription, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />

                            <TextBlock
                                Foreground="{StaticResource AppMutedBrush}"
                                Text="With loop on, Indolent keeps answering and clicking through visible questions until it no longer finds another answerable one, then reports how many it finished."
                                TextWrapping="WrapWholeWords"
                                Visibility="{x:Bind ViewModel.ShowAgentLoopVisibility, Mode=OneWay}" />

                            <TextBlock
                                Foreground="{StaticResource AppMutedBrush}"
                                Text="{x:Bind ViewModel.ProviderBehaviorText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Padding="20"
                    Background="{StaticResource AppSubtleCardBrush}"
                    BorderBrush="{StaticResource AppCardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{x:Bind ViewModel.ShowInstallBlockerVisibility, Mode=OneWay}">
                    <StackPanel Spacing="16">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="{x:Bind ViewModel.BlockingTitle, Mode=OneWay}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.BlockingMessage, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            Foreground="{StaticResource AppMutedBrush}"
                            Text="{x:Bind ViewModel.GuidedSetupDescription, Mode=OneWay}"
                            TextWrapping="WrapWholeWords"
                            Visibility="{x:Bind ViewModel.ShowGuidedSetupVisibility, Mode=OneWay}" />
                        <TextBlock
                            Foreground="{StaticResource AppMutedBrush}"
                            Text="{x:Bind ViewModel.SetupStatusText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords"
                            Visibility="{x:Bind ViewModel.ShowSetupStatusVisibility, Mode=OneWay}" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                Click="OnRunGuidedSetupClicked"
                                Content="Run guided setup"
                                IsEnabled="{x:Bind ViewModel.CanRunGuidedSetup, Mode=OneWay}"
                                Style="{StaticResource AccentButtonStyle}"
                                Visibility="{x:Bind ViewModel.ShowGuidedSetupVisibility, Mode=OneWay}" />
                            <Button
                                Click="OnOpenInstallGuideClicked"
                                Content="Open install guide" />
                            <Button
                                Click="OnRefreshClicked"
                                Content="Re-check" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Padding="20"
                    Background="{StaticResource AppSubtleCardBrush}"
                    BorderBrush="{StaticResource AppCardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="12">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="CLI wrapper behavior" />
                        <TextBlock
                            Foreground="{StaticResource AppMutedBrush}"
                            Text="{x:Bind ViewModel.ProviderBehaviorText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid
            Grid.Row="1"
            MaxWidth="920"
            Padding="32,8,32,32"
            RowSpacing="16"
            Visibility="{x:Bind ViewModel.ShowTerminalViewVisibility, Mode=OneWay}">
            <Grid RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="{x:Bind ViewModel.TerminalTitle, Mode=OneWay}" />
                    <TextBlock
                        Foreground="{StaticResource AppMutedBrush}"
                        Text="{x:Bind ViewModel.TerminalDescription, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    Background="{StaticResource AppCardBrush}"
                    BorderBrush="{StaticResource AppCardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <ScrollViewer
                        x:Name="TerminalTranscriptScrollViewer"
                        HorizontalScrollBarVisibility="Auto"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollBarVisibility="Auto"
                        VerticalScrollMode="Enabled"
                        ZoomMode="Disabled">
                        <TextBlock
                            Padding="16"
                            FontFamily="Consolas"
                            FontSize="13"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind ViewModel.TerminalTranscript, Mode=OneWay}"
                            TextWrapping="NoWrap" />
                    </ScrollViewer>
                </Border>

                <TextBlock
                    Grid.Row="2"
                    Foreground="{StaticResource AppMutedBrush}"
                    Text="{x:Bind ViewModel.TerminalArgumentsLabel, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />

                <Grid
                    Grid.Row="3"
                    ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        Grid.Column="0"
                        KeyDown="OnTerminalCommandKeyDown"
                        PlaceholderText="--help"
                        Text="{x:Bind ViewModel.TerminalCommandText, Mode=TwoWay}" />

                    <Button
                        Grid.Column="1"
                        Click="OnRunTerminalCommandClicked"
                        Content="Run"
                        IsEnabled="{x:Bind ViewModel.CanRunTerminalCommand, Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}" />

                    <Button
                        Grid.Column="2"
                        Click="OnClearTerminalClicked"
                        Content="Clear" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>

