<Window
    x:Class="Indolent.WidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid
        x:Name="RootGrid"
        Width="420"
        Height="112"
        Background="Transparent"
        PointerEntered="OnRootPointerEntered"
        PointerExited="OnRootPointerExited"
        PointerPressed="OnRootPointerPressed">
        <Grid.Resources>
            <TransitionCollection x:Key="FadeTransitions">
                <EntranceThemeTransition />
            </TransitionCollection>
            <Storyboard x:Key="ThinkingSweepStoryboard" RepeatBehavior="Forever">
                <DoubleAnimation
                    Storyboard.TargetName="ThinkingSweepTransform"
                    Storyboard.TargetProperty="X"
                    Duration="0:0:2.6"
                    From="-140"
                    To="264" />
            </Storyboard>
        </Grid.Resources>

        <Grid.Transitions>
            <StaticResource ResourceKey="FadeTransitions" />
        </Grid.Transitions>

        <Border
            Background="{StaticResource WidgetOuterGlowBrush}"
            CornerRadius="56"
            Opacity="0.9" />

        <Border
            Margin="1.5"
            BorderBrush="{StaticResource WidgetStrokeBrush}"
            BorderThickness="1.1"
            CornerRadius="54.5"
            Opacity="0.95" />

        <Border
            Margin="4"
            Background="{StaticResource WidgetBodyBrush}"
            BorderBrush="{StaticResource WidgetStrokeBrush}"
            BorderThickness="1"
            CornerRadius="52">
            <Grid>
                <Border
                    Margin="11,9,11,50"
                    Background="{StaticResource WidgetHighlightBrush}"
                    CornerRadius="42"
                    Height="20"
                    Opacity="0.36"
                    VerticalAlignment="Top" />

                <Border
                    Margin="20,14,20,18"
                    Background="{StaticResource WidgetInnerSheenBrush}"
                    CornerRadius="44"
                    Opacity="0.14" />

                <Border
                    Margin="88,18,88,26"
                    Background="{StaticResource WidgetCenterGlowBrush}"
                    CornerRadius="40"
                    Opacity="0.22" />

                <Ellipse
                    Fill="{StaticResource WidgetTopSpecBrush}"
                    Width="94"
                    Height="28"
                    HorizontalAlignment="Left"
                    IsHitTestVisible="False"
                    Margin="34,16,0,0"
                    Opacity="0.5"
                    VerticalAlignment="Top" />

                <Ellipse
                    Fill="{StaticResource WidgetTopSpecBrush}"
                    Width="98"
                    Height="30"
                    HorizontalAlignment="Right"
                    IsHitTestVisible="False"
                    Margin="0,15,34,0"
                    Opacity="0.54"
                    VerticalAlignment="Top" />

                <Grid Margin="34,0">
                    <Grid
                        x:Name="ThinkingTextPresenter"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0"
                        MaxWidth="258"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                        <TextBlock
                            Foreground="{StaticResource WidgetThinkingBaseTextBrush}"
                            HorizontalAlignment="Center"
                            MaxWidth="258"
                            Style="{StaticResource WidgetThinkingTextStyle}"
                            Text="{x:Bind ViewModel.MessageText, Mode=OneWay}"
                            TextAlignment="Center"
                            TextWrapping="NoWrap" />

                        <TextBlock
                            Foreground="{StaticResource WidgetThinkingSweepTextBrush}"
                            HorizontalAlignment="Center"
                            IsHitTestVisible="False"
                            MaxWidth="258"
                            Opacity="0.52"
                            Style="{StaticResource WidgetThinkingTextStyle}"
                            Text="{x:Bind ViewModel.MessageText, Mode=OneWay}"
                            TextAlignment="Center"
                            TextWrapping="NoWrap">
                            <TextBlock.Clip>
                                <RectangleGeometry Rect="0,0,92,64">
                                    <RectangleGeometry.Transform>
                                        <TranslateTransform x:Name="ThinkingSweepTransform" X="-140" />
                                    </RectangleGeometry.Transform>
                                </RectangleGeometry>
                            </TextBlock.Clip>
                        </TextBlock>
                    </Grid>

                    <TextBlock
                        x:Name="MessageTextBlock"
                        HorizontalAlignment="Center"
                        Margin="0,7,0,0"
                        MaxWidth="236"
                        Style="{StaticResource WidgetResultTextStyle}"
                        Text="{x:Bind ViewModel.MessageText, Mode=OneWay}"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="WrapWholeWords"
                        VerticalAlignment="Center"
                        Visibility="Collapsed" />

                    <Button
                        x:Name="AnswerButton"
                        Click="OnAnswerClicked"
                        Content="Answer"
                        HorizontalAlignment="Center"
                        Style="{StaticResource WidgetAnswerButtonStyle}"
                        VerticalAlignment="Center"
                        Visibility="Collapsed" />
                </Grid>

                <Border
                    Margin="104,0,104,12"
                    Background="{StaticResource WidgetBottomGlowBrush}"
                    CornerRadius="6"
                    Height="8"
                    Opacity="0.56"
                    VerticalAlignment="Bottom" />

                <Border
                    Margin="68,0,68,13"
                    Background="{StaticResource WidgetBottomLineBrush}"
                    CornerRadius="1"
                    Height="1"
                    Opacity="0.74"
                    VerticalAlignment="Bottom" />
            </Grid>
        </Border>
    </Grid>
</Window>
