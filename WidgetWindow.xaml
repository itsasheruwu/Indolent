<Window
    x:Class="Indolent.WidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:helpers="using:Indolent.Helpers"
    mc:Ignorable="d">
    <Grid
        x:Name="RootGrid"
        Background="{StaticResource WidgetBackgroundBrush}">
        <Grid.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem
                    Click="OnOpenMainWindowMenuItemClicked"
                    Text="Open main window" />
                <MenuFlyoutItem
                    Click="OnForceStopMenuItemClicked"
                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                    Text="Force stop current answer" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    Click="OnHideWidgetMenuItemClicked"
                    Text="Hide widget" />
            </MenuFlyout>
        </Grid.ContextFlyout>
        <Grid.Resources>
            <!-- Minimal opacity fade for thinking state -->
            <Storyboard x:Key="ThinkingRevealStoryboard">
                <DoubleAnimation
                    Storyboard.TargetName="ThinkingTextPresenter"
                    Storyboard.TargetProperty="Opacity"
                    Duration="0:0:0.25"
                    From="0"
                    To="1" />
            </Storyboard>
            <Storyboard x:Key="MessageRevealStoryboard">
                <DoubleAnimation
                    Storyboard.TargetName="MessageTextBlock"
                    Storyboard.TargetProperty="Opacity"
                    Duration="0:0:0.25"
                    From="0"
                    To="1" />
            </Storyboard>
            <Storyboard x:Key="ActionButtonRevealStoryboard">
                <DoubleAnimation
                    Storyboard.TargetName="AnswerButton"
                    Storyboard.TargetProperty="Opacity"
                    Duration="0:0:0.25"
                    From="0"
                    To="1" />
            </Storyboard>
            <Storyboard x:Key="SubtleBorderGlowStoryboard" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation
                    Storyboard.TargetName="ActiveHighlightBorder"
                    Storyboard.TargetProperty="Opacity"
                    Duration="0:0:1.5"
                    From="0.2"
                    To="1.0">
                    <DoubleAnimation.EasingFunction>
                        <SineEase EasingMode="EaseInOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            <Storyboard x:Key="ThinkingTextShimmerStoryboard" RepeatBehavior="Forever">
                <DoubleAnimation
                    Storyboard.TargetName="ThinkingTextShimmerTransform"
                    Storyboard.TargetProperty="X"
                    Duration="0:0:3.6"
                    From="-1.35"
                    To="1.35">
                    <DoubleAnimation.EasingFunction>
                        <SineEase EasingMode="EaseInOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            <LinearGradientBrush x:Key="WidgetThinkingTextShimmerBrush" StartPoint="0,0.5" EndPoint="1,0.5">
                <LinearGradientBrush.RelativeTransform>
                    <TranslateTransform x:Name="ThinkingTextShimmerTransform" X="-1.35" />
                </LinearGradientBrush.RelativeTransform>
                <GradientStop Color="{StaticResource WidgetThinkingTextBaseColor}" Offset="0.00" />
                <GradientStop Color="{StaticResource WidgetThinkingTextBaseColor}" Offset="0.28" />
                <GradientStop Color="{StaticResource WidgetThinkingTextSweepSoftColor}" Offset="0.41" />
                <GradientStop Color="{StaticResource WidgetThinkingTextSweepPeakColor}" Offset="0.50" />
                <GradientStop Color="{StaticResource WidgetThinkingTextSweepSoftColor}" Offset="0.59" />
                <GradientStop Color="{StaticResource WidgetThinkingTextBaseColor}" Offset="0.72" />
                <GradientStop Color="{StaticResource WidgetThinkingTextBaseColor}" Offset="1.00" />
            </LinearGradientBrush>
        </Grid.Resources>

        <helpers:CursorGrid
            x:Name="WidgetSurface"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            PointerEntered="OnSurfacePointerEntered"
            PointerExited="OnSurfacePointerExited"
            PointerMoved="OnDragAreaPointerMoved"
            PointerReleased="OnDragAreaPointerReleased">
            
            <Grid x:Name="SurfaceGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="38" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Drag Handle -->
                <helpers:DragGrid
                    x:Name="DragHandleArea"
                    Grid.Column="0"
                    Background="#01000000"
                    PointerEntered="OnDragHandlePointerEntered"
                    PointerExited="OnDragHandlePointerExited"
                    PointerPressed="OnDragAreaPointerPressed">
                    <!-- Subtle grip lines -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="3">
                        <Border Width="12" Height="2" CornerRadius="1" Background="{StaticResource WidgetDragHandleBrush}" />
                        <Border Width="12" Height="2" CornerRadius="1" Background="{StaticResource WidgetDragHandleBrush}" />
                        <Border Width="12" Height="2" CornerRadius="1" Background="{StaticResource WidgetDragHandleBrush}" />
                    </StackPanel>
                </helpers:DragGrid>

                <!-- Separator -->
                <Border
                    Grid.Column="0"
                    Width="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Margin="0,16,0,16"
                    Background="{StaticResource WidgetDragHandleBrush}" />

                <!-- Content Area -->
                <Grid
                    x:Name="ContentArea"
                    Grid.Column="1"
                    Background="#01000000"
                    PointerPressed="OnContentAreaPointerPressed"
                    PointerReleased="OnContentAreaPointerReleased">
                    
                    <Grid Margin="20,10,20,10">
                        <Grid
                            x:Name="ThinkingTextPresenter"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Opacity="0"
                            Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <muxc:ProgressRing
                                    x:Name="StatusProgressRing"
                                    Width="16"
                                    Height="16"
                                    Foreground="{StaticResource WidgetThinkingTextBrush}"
                                    IsActive="{x:Bind ViewModel.ShowStatusSpinner, Mode=OneWay}" />
                                <TextBlock
                                    x:Name="OcrStatusIcon"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Foreground="{StaticResource WidgetWarningIconBrush}"
                                    Text="&#xE721;"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed" />
                                <TextBlock
                                    x:Name="ScreenshotStatusIcon"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Foreground="{StaticResource WidgetWarningIconBrush}"
                                    Text="&#xE722;"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed" />
                                <TextBlock
                                    x:Name="ThinkingTextBlock"
                                    Style="{StaticResource WidgetThinkingTextStyle}"
                                    Foreground="{StaticResource WidgetThinkingTextShimmerBrush}"
                                    Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock
                            x:Name="MessageTextBlock"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Opacity="0"
                            Style="{StaticResource WidgetResultTextStyle}"
                            Text="{x:Bind ViewModel.MessageText, Mode=OneWay}"
                            Visibility="Collapsed" />

                        <Button
                            x:Name="AnswerButton"
                            Click="OnAnswerButtonClicked"
                            Content="Answer"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Opacity="0"
                            Style="{StaticResource WidgetAnswerButtonStyle}"
                            Visibility="Collapsed" />
                    </Grid>
                </Grid>

                <!-- Active Glow Line (bottom) -->
                <Border
                    x:Name="ActiveHighlightBorder"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Height="2"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource WidgetActiveHighlightBrush}"
                    Opacity="0"
                    Visibility="Collapsed" />
            </Grid>
        </helpers:CursorGrid>
    </Grid>
</Window>
